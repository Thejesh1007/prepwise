generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String             @id @default(cuid())
  name      String
  email     String             @unique
  password  String
  createdAt DateTime           @default(now())
  contents  GeneratedContent[]
}

model GeneratedContent {
  id        String   @id @default(cuid())
  userId    String
  mode      Mode
  topic     String
  subject   String
  options   Json
  output    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Mode {
  DESCRIPTIVE
  OBJECTIVE
  SEMINAR
}